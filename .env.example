# Required: Groq API key for Llama 3 models
# Get one at https://console.groq.com/keys
GROQ_API_KEY=
# Optional: override the model used for all agents.
# llama-3.3-70b-versatile is the default -- fast and capable.
GROQ_MODEL=llama-3.3-70b-versatile

# Required for the sentiment analyst's live news search.
# Free tier (1000 searches/month) at https://tavily.com
TAVILY_API_KEY=
